package main

import "fmt"

const demoConst = "const"

var demoVar = map[string]int{"go": 1}

type speaker interface {
	Speak() string
}

type robot struct {
	name string
}

func (r robot) Speak() string {
	return "hi " + r.name
}

func choose(n int) string {
	switch {
	case n < 0:
		return "neg"
	case n == 0:
		fallthrough
	default:
		return "non-neg"
	}
}

func channelDemo() int {
	ch := make(chan int, 1)
	go func() {
		defer close(ch)
		ch <- 7
	}()

	var out int
	select {
	case out = <-ch:
	}
	return out
}

func loopDemo() int {
	nums := []int{1, 2, 3}
	sum := 0
	for i, v := range nums {
		if i == 1 {
			continue
		} else if v < 0 {
			goto end
		}
		sum += v
		if sum > 10 {
			break
		}
	}

end:
	return sum
}

func typeDemo(x interface{}) string {
	switch x.(type) {
	case int:
		return "int"
	default:
		return "other"
	}
}

func main() {
	s := speaker(robot{name: "gopher"})
	fmt.Println("const:", demoConst)
	fmt.Println("speak:", s.Speak())
	fmt.Println("choose:", choose(0))
	fmt.Println("loop:", loopDemo())
	fmt.Println("type:", typeDemo(3))
	fmt.Println("select-recv:", channelDemo())

	_, ok := demoVar["go"]
	if !ok {
		return
	}

	fmt.Println("ALL_GO_KEYWORDS_OK")
}
