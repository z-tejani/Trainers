cat >"$TRAINER_WORKDIR/counter/counter_test.go" <<'COUNTERTEST'
package counter

import (
	"sync"
	"testing"
)

func TestSafeCounterParallel(t *testing.T) {
	var c SafeCounter
	var wg sync.WaitGroup

	for i := 0; i < 100; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			c.Inc()
		}()
	}

	wg.Wait()
	if got := c.Value(); got != 100 {
		t.Fatalf("counter=%d, want 100", got)
	}
}

func TestSumViaChannel(t *testing.T) {
	if got := SumViaChannel([]int{1, 2, 3, 4}); got != 10 {
		t.Fatalf("sum=%d, want 10", got)
	}
}
