cat >"$TRAINER_WORKDIR/calc/calc.go" <<'CALC'
package calc

func Fib(n int) int {
	if n < 2 {
		return n
	}
	a, b := 0, 1
	for i := 2; i <= n; i++ {
		a, b = b, a+b
	}
	return b
}

func FibRec(n int) int {
	if n < 2 {
		return n
	}
	return FibRec(n-1) + FibRec(n-2)
}

func Sum(nums []int) int {
	total := 0
	for _, n := range nums {
		total += n
	}
	return total
}
