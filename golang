package main

import (
	"errors"
	"fmt"
)

var ErrNotFound = errors.New("not found")

type ParseError struct {
	Field string
}

func (e *ParseError) Error() string {
	return "invalid field: " + e.Field
}

func wrapErr() error {
	return fmt.Errorf("lookup user: %w", ErrNotFound)
}

func typedErr() error {
	return &ParseError{Field: "email"}
}

func main() {
	err1 := wrapErr()
	fmt.Println("is-not-found:", errors.Is(err1, ErrNotFound))

	err2 := typedErr()
	var pe *ParseError
	fmt.Println("as-parse-error:", errors.As(err2, &pe))
}
