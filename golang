cat >"$TRAINER_WORKDIR/counter/counter.go" <<'COUNTER'
package counter

import "sync"

type SafeCounter struct {
	mu sync.Mutex
	n  int
}

func (c *SafeCounter) Inc() {
	c.mu.Lock()
	c.n++
	c.mu.Unlock()
}

func (c *SafeCounter) Value() int {
	c.mu.Lock()
	defer c.mu.Unlock()
	return c.n
}

func SumViaChannel(nums []int) int {
	in := make(chan int)
	done := make(chan int)
	go func() {
		total := 0
		for n := range in {
			total += n
		}
		done <- total
	}()
	for _, n := range nums {
		in <- n
	}
	close(in)
	return <-done
}
