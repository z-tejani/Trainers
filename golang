package main

import (
	"context"
	"fmt"
	"time"
)

func main() {
	ctx, cancel := context.WithTimeout(context.Background(), 20*time.Millisecond)
	defer cancel()

	workDone := make(chan struct{})
	go func() {
		defer close(workDone)
		select {
		case <-time.After(50 * time.Millisecond):
		case <-ctx.Done():
		}
	}()

	<-ctx.Done()
	<-workDone
	fmt.Println(ctx.Err())
}
